{
  "name": "aianalist-bun-express-server",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun run --watch src/index.ts",
    "build": "tsc && bun build:post",
    "build:post": "cp -r ./_core ./dist/_core && cp -r ./environment ./dist/environment",
    "start": "NODE_ENV=production bun ./dist/index.js",
    "clean": "rm -rf dist",
    "build:clean": "bun run clean && bun run build"
  },
  "dependencies": {
    "@types/cors": "^2.8.17",
    "@types/lodash": "^4.17.14",
    "@types/supertest": "^6.0.2",
    "colorette": "^2.0.20",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-route-tracker": "^2.0.72",
    "firebase": "^11.2.0",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.0.0",
    "lodash": "^4.17.21",
    "reflect-metadata": "^0.2.2",
    "typedi": "^0.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "bun-types": "latest",
    "typescript": "^5.3.3"
  }
}